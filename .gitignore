# build output
dist/
.astro/

# Icon-build inputs (font binaries fetched at build time, not source)
scripts/_assets/

# Local design-iteration pages. Used for in-browser exploration; never ship.
src/pages/dev/

# inbox: drop folder for raw article drafts. Keep the scaffolding, ignore the drops.
inbox/*
!inbox/README.md
!inbox/_TEMPLATE.md

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production
.env.local
.env.*.local

# macOS / Windows
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/
*.swp

# audit scratch (kept locally as evidence, not for repo)
# audit-evidence/  — left in for now; revisit if it bloats

# Local-only assets: candidate photos / reference materials that didn't make
# it to public/. Kept locally for future iterations, not in repo.
assets/

# Internal working doc with real client names. Public version with
# anonymized signals lives in src/content/cases/ and in
# "[on] Public Portfolio 32-cases.md". This file must NEVER be tracked.
# (Square brackets escaped because [on] would otherwise match any of o,n.)
\[on\] Portfolio-Projects-by-business-theme.md

# Local debug screenshots (Wix DNS panels, Netlify dashboards during cutover).
# Reference only, not for the repo. Allowlist public/ images by exception.
*.jpg
*.jpeg
*.png
!public/**/*.jpg
!public/**/*.jpeg
!public/**/*.png
