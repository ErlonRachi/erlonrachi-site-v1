---
/* Temporary dev nav: cross-links between the layout variants + signature
 * component demo. Removed once one layout is picked. */
const current = Astro.url.pathname;
const links = [
  { href: "/", label: "Painted Highlight demo" },
  { href: "/work", label: "Work / portfolio index" },
  { href: "/work/all", label: "Work / all" },
];
---

<nav class="dev-nav" aria-label="Layout variants">
  <span class="dev-nav__label">DEV NAV</span>
  {links.map(({ href, label }) => (
    <a href={href} class:list={["dev-nav__link", { "is-current": current === href }]}>{label}</a>
  ))}
</nav>

<style>
  .dev-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px;
    padding: 12px 24px;
    background: var(--europa-blue-deeper);
    border-bottom: 1px solid rgba(230, 228, 218, 0.1);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dev-nav__label {
    color: var(--paper-muted);
    margin-right: 8px;
  }

  .dev-nav__link {
    color: var(--paper-soft);
    text-decoration: none;
    transition: color 120ms;
  }

  .dev-nav__link:hover {
    color: var(--paper);
  }

  .dev-nav__link.is-current {
    color: var(--splash);
  }
</style>
