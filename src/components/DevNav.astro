---
/* Temporary dev nav: cross-links between the layout variants + signature
 * component demo. Removed once one layout is picked. */
const current = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/work", label: "Work / index" },
  { href: "/work/regulator-compliance-automation", label: "Work / sample case" },
  { href: "/writing", label: "Writing / index" },
  { href: "/writing/from-input-output-to-intent", label: "Writing / sample essay" },
  { href: "/story", label: "Story" },
  { href: "/work-with-me", label: "Work with me" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="dev-nav" aria-label="Layout variants">
  <span class="dev-nav__label">DEV NAV</span>
  {links.map(({ href, label }) => (
    <a href={href} class:list={["dev-nav__link", { "is-current": current === href }]}>{label}</a>
  ))}
</nav>

<style>
  .dev-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px;
    padding: 12px 24px;
    background: var(--europa-blue-deeper);
    border-bottom: 1px solid var(--border-medium);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dev-nav__label {
    color: var(--paper-muted);
    margin-right: 8px;
  }

  .dev-nav__link {
    color: var(--paper-soft);
    text-decoration: none;
    transition: color 120ms;
  }

  .dev-nav__link:hover {
    color: var(--paper);
  }

  .dev-nav__link.is-current {
    color: var(--splash);
  }
</style>
