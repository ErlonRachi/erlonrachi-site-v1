---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"cases">;
}

const { entry } = Astro.props;
const { title, client, year, metric } = entry.data;
const href = `/work/${entry.id}`;
---

<a class="case-card" href={href}>
  <p class="case-card__meta">
    <span class="case-card__client">{client}</span>
    <span class="case-card__sep">·</span>
    <span class="case-card__year">{year}</span>
  </p>
  <h3 class="case-card__title">{title}</h3>
  <p class="case-card__metric">{metric}</p>
  <span class="case-card__arrow" aria-hidden="true">→</span>
</a>

<style>
  .case-card {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "meta meta"
      "title arrow"
      "metric metric";
    column-gap: 16px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border-medium);
    text-decoration: none;
    color: inherit;
    transition: background 160ms var(--ease-quart);
  }

  .case-card:hover,
  .case-card:focus-visible {
    background: var(--accent-faint-grad);
    outline: none;
  }

  .case-card:focus-visible {
    outline: 2px solid var(--splash);
    outline-offset: 2px;
  }

  .case-card:last-child {
    border-bottom: 0;
  }

  .case-card__meta {
    grid-area: meta;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--paper-muted);
    margin: 0 0 10px;
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .case-card__client {
    color: var(--paper-soft);
  }

  .case-card__sep {
    color: var(--paper-muted);
    opacity: 0.6;
  }

  .case-card__title {
    grid-area: title;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-variation-settings: "opsz" 144, "SOFT" 30;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--paper);
    margin: 0 0 10px;
    max-width: 38ch;
  }

  .case-card__arrow {
    grid-area: arrow;
    align-self: start;
    padding-top: 4px;
    color: var(--splash);
    font-family: "Fraunces", Georgia, serif;
    font-size: 22px;
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 180ms var(--ease-quart), transform 180ms var(--ease-quart);
  }

  .case-card:hover .case-card__arrow,
  .case-card:focus-visible .case-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .case-card__metric {
    grid-area: metric;
    font-size: 16px;
    line-height: 1.55;
    color: var(--paper-soft);
    margin: 0;
    max-width: 60ch;
  }
</style>
