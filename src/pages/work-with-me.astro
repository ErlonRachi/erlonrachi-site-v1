---
import Layout from "../layouts/Layout.astro";
import DevNav from "../components/DevNav.astro";
import PaintedHighlight from "../components/PaintedHighlight.astro";

const fractionalTiers = [
  {
    n: 1,
    name: "Agentic AI Readiness Diagnostic",
    duration: "2 weeks",
    who: "A CEO, COO, or CTO who knows they need to act on AI but does not know what to ship first or how exposed they are under the EU AI Act.",
    what: [
      "Mapped inventory of AI use cases already in flight (sanctioned and shadow)",
      "EU AI Act risk classification of each",
      "A 90-day action plan: what to kill, what to harden, what to pilot",
      "A 30-minute presentation to the leadership team",
    ],
    why: "Low commitment, fast turnaround. The output naturally creates demand for Tier 2. Diagnostic-to-engagement pattern of the best fractional CAIOs.",
    cta: "Start with the Diagnostic",
    slug: "fractional-diagnostic",
  },
  {
    n: 2,
    name: "Fractional Head of AI",
    duration: "90-day sprint, renewable",
    who: "A scale-up or mid-market company that needs an executive in the room two days a week to set strategy, hire the right people, ship the first production agentic workflow, and stand up MLOps and governance from day one.",
    what: [
      "Embedded leadership presence (defined cadence)",
      "Strategy document and 90-day roadmap, owned end to end",
      "One production-grade agentic workflow shipped",
      "Governance scaffolding (data lineage, model cards, EU AI Act docs)",
      "A trained internal lead by day 90: capability transfer is the deliverable",
    ],
    why: "Bread and butter. Where applied math, leadership chops, and Iarandu's delivery muscle compound. The 'trained successor' line settles consultant-lock-in concerns.",
    cta: "Discuss a Fractional engagement",
    slug: "fractional-head-of-ai",
  },
  {
    n: 3,
    name: "AI Operating Council",
    duration: "Monthly retainer",
    who: "A board or exec team that already has AI capability but wants a senior independent voice in their quarterly cycle.",
    what: [
      "Monthly half-day strategy session",
      "Async review of major decisions",
      "Quarterly written outlook on regulation, vendor landscape, and team health",
    ],
    why: "Predictable monthly cadence, low time cost. Signals 'the kind of person companies retain' to anyone evaluating. Doubles as recruiter validation.",
    cta: "Join the Council",
    slug: "fractional-council",
  },
];

const builderTiers = [
  {
    n: 1,
    name: "Technical Readiness Audit",
    duration: "2 weeks",
    who: "A CTO, Head of Engineering, or VP Data who suspects technical debt is blocking AI or data ambitions.",
    what: [
      "Stack assessment (data infrastructure, AI/ML layer, compliance posture)",
      "Bottleneck inventory: what hurts, what scales, what will break",
      "A 60-day technical roadmap with the recommended sequence of builds",
      "A 30-minute presentation to the technical leadership",
    ],
    why: "Low-commitment proof of competence. Output generates Tier 2 demand. The technical mirror of the Diagnostic in the Fractional track.",
    cta: "Start with the Audit",
    slug: "builder-audit",
  },
  {
    n: 2,
    name: "Embedded Builder Sprint",
    duration: "8 to 12 weeks, renewable",
    who: "A team that needs a senior practitioner hands-on to ship a specific production artifact: an agentic workflow, a data architecture refactor, an MLOps platform, a compliance framework, or a critical data engineering pipeline.",
    what: [
      "Code shipped to production: the artifact IS the deliverable",
      "Architecture documentation",
      "One internal team member trained as owner",
      "Repo handed off with tests and CI/CD ready",
    ],
    why: "Pure shipping mode. 3 days a week in the codebase. Capability transfer through the trained owner. The technical mirror of the Fractional Head of AI's 'trained successor'.",
    cta: "Discuss a Builder Sprint",
    slug: "builder-sprint",
  },
  {
    n: 3,
    name: "Architecture Retainer",
    duration: "Monthly",
    who: "A technical team that wants ongoing senior architectural review without re-engagement overhead.",
    what: [
      "Bi-weekly architecture office hours (1 hour)",
      "Async review of major designs and PRs (48-hour turnaround)",
      "Quarterly stack health review (written and sync)",
    ],
    why: "Predictable cash, low time cost. The 'senior architect on call' signal. Renewable monthly.",
    cta: "Join the Retainer",
    slug: "builder-retainer",
  },
];
---

<Layout
  title="Work with me — Erlon Rachi"
  description="Two productized engagement tracks: Fractional Executive (Erlon in the decision room) and Embedded Builder (Erlon in the codebase). Six tiers, request-a-quote."
>
  <DevNav />

  <main class="engage mx-auto max-w-[1180px] px-6 py-16 md:py-24">
    <p class="label-mono">Engage</p>
    <h1 class="display-xl engage__h1">
      Two ways to <PaintedHighlight>work with me</PaintedHighlight>.
    </h1>

    <p class="engage__lead">
      The question is simple: do you need an executive in the decision room, or a builder in the codebase? Both are senior. Both are me. Different roles, different cadences, different deliverables. Pick the lane that fits the problem, request a quote, and we will talk.
    </p>

    <aside class="engage__note">
      <p class="label-mono engage__note-label">A note on <PaintedHighlight>full-time</PaintedHighlight> position</p>
      <p class="engage__note-question">Are you considering me for a full-time executive role?</p>
      <p>This conversation does not live on this page. Feel free to drop me a message on <a href="https://www.linkedin.com/in/erlonrachi/" rel="me noopener">LinkedIn</a>. Let's have a meaningful conversation.</p>
    </aside>

    <div class="tracks">
      {/* Track A: Fractional Executive */}
      <details class="track">
        <summary class="track__summary">
          <div class="track__summary-text">
            <p class="track__label"><PaintedHighlight>Track A</PaintedHighlight></p>
            <h2 class="track__title">Fractional Executive</h2>
            <p class="track__sub">Erlon in the decision room. Structuring teams, setting strategy, advising, building organisations through the team.</p>
          </div>
          <span class="track__indicator" aria-hidden="true"></span>
        </summary>
        <div class="tier-stack">
          {fractionalTiers.map((t) => (
            <details class="tier">
              <summary class="tier__summary">
                <div class="tier__summary-text">
                  <p class="label-mono tier__meta">Tier {t.n} · {t.duration}</p>
                  <h3 class="tier__name">{t.name}</h3>
                </div>
                <span class="tier__indicator" aria-hidden="true"></span>
              </summary>
              <div class="tier__expanded">
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">Who it's for</p>
                  <p class="tier__body">{t.who}</p>
                </div>
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">What you get</p>
                  <ul class="tier__list">
                    {t.what.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">Why it works</p>
                  <p class="tier__body tier__body--italic">{t.why}</p>
                </div>
                <a href={`/contact?tier=${t.slug}`} class="tier__cta">{t.cta} →</a>
              </div>
            </details>
          ))}
        </div>
      </details>

      {/* Track B: Embedded Builder */}
      <details class="track">
        <summary class="track__summary">
          <div class="track__summary-text">
            <p class="track__label"><PaintedHighlight>Track B</PaintedHighlight></p>
            <h2 class="track__title">Embedded Builder</h2>
            <p class="track__sub">Erlon in the codebase. Shipping production artifacts. Builder, shipper, executioner.</p>
          </div>
          <span class="track__indicator" aria-hidden="true"></span>
        </summary>
        <div class="tier-stack">
          {builderTiers.map((t) => (
            <details class="tier">
              <summary class="tier__summary">
                <div class="tier__summary-text">
                  <p class="label-mono tier__meta">Tier {t.n} · {t.duration}</p>
                  <h3 class="tier__name">{t.name}</h3>
                </div>
                <span class="tier__indicator" aria-hidden="true"></span>
              </summary>
              <div class="tier__expanded">
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">Who it's for</p>
                  <p class="tier__body">{t.who}</p>
                </div>
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">What you get</p>
                  <ul class="tier__list">
                    {t.what.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
                <div class="tier__section">
                  <p class="label-mono tier__sub-label">Why it works</p>
                  <p class="tier__body tier__body--italic">{t.why}</p>
                </div>
                <a href={`/contact?tier=${t.slug}`} class="tier__cta">{t.cta} →</a>
              </div>
            </details>
          ))}
        </div>
      </details>
    </div>

    <footer class="engage__footer">
      <p class="label-mono">No prices on the page</p>
      <p class="engage__footer-body">
        Quotes are conversation-driven. Tell me the problem, the timeline, and the stakeholders, and I will scope. If we are not a fit, I will say so directly.
      </p>
    </footer>
  </main>
</Layout>

<style>
  /* Intro block — centered to match the 2-track grid below */
  .engage > .label-mono {
    text-align: center;
  }

  .engage__h1 {
    text-align: center;
    margin: 14px auto 40px;
    max-width: 18ch;
  }

  .engage__lead {
    font-size: 19px;
    line-height: 1.65;
    color: var(--paper);
    max-width: 65ch;
    margin: 0 auto 28px;
    text-align: center;
  }

  /* Full-time aside: centered, capped width, gold accent on top.
   * Mirrors the home page FT aside pattern. */
  .engage__note {
    padding: 28px 32px;
    border-top: 2px solid var(--accent-soft);
    background: var(--surface-tint);
    margin: 0 auto 80px;
    max-width: 760px;
    text-align: center;
  }

  .engage__note-label {
    margin: 0 0 18px;
  }

  .engage__note p:not(.label-mono) {
    margin: 0 auto;
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--paper-soft);
    max-width: 60ch;
  }

  .engage__note p.engage__note-question {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-style: italic;
    font-size: 19px;
    line-height: 1.4;
    letter-spacing: -0.005em;
    color: var(--paper);
    margin: 0 auto 16px;
    max-width: 52ch;
  }

  .engage__note a {
    color: var(--paper-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-soft);
    transition: color 140ms, text-decoration-color 140ms;
  }

  .engage__note a:hover {
    color: var(--paper);
    text-decoration-color: var(--splash);
  }

  /* Two-track parallel layout: stacks on mobile, side-by-side on desktop.
   * align-items: start so an opened track does not stretch the closed one. */
  .tracks {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }

  @media (min-width: 1000px) {
    .tracks {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
  }

  /* Track: outer accordion. Click summary to reveal the 3 tier accordions. */
  .track {
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    transition: border-color 200ms var(--ease-quart), background 200ms var(--ease-quart);
  }

  .track[open] {
    border-color: var(--accent-strong);
    background: var(--surface-card-open);
  }

  .track__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    padding: 28px 28px;
    transition: background 140ms;
  }

  /* Equalize closed-state height on desktop so the two boxes pair visually
   * regardless of sub-description length. Mobile (stacked) does not need it. */
  @media (min-width: 1000px) {
    .track__summary {
      min-height: 240px;
    }
  }

  .track__summary::-webkit-details-marker { display: none; }
  .track__summary::marker { display: none; }

  .track__summary:hover {
    background: var(--accent-faint);
  }

  /* Keyboard focus: visible splash outline. Global :focus-visible already
   * provides a fallback, but summaries benefit from a more deliberate state. */
  .track__summary:focus-visible {
    outline: 2px solid var(--splash);
    outline-offset: 2px;
    background: var(--accent-faint);
  }

  .track__summary-text {
    flex: 1;
    min-width: 0;
  }

  /* Track label gets the painted highlight signature. Inline-block keeps
   * the highlight from spanning the whole line. */
  .track__label {
    margin: 0 0 14px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
  }

  .track__title {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: clamp(28px, 3vw, 36px);
    line-height: 1.12;
    letter-spacing: -0.014em;
    color: var(--paper);
    margin: 8px 0 12px;
  }

  .track__sub {
    font-size: 16px;
    line-height: 1.55;
    color: var(--paper-soft);
    margin: 0;
    font-style: italic;
    max-width: 42ch;
  }

  /* Track plus-indicator (larger than tier indicator) */
  .track__indicator {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    margin-top: 12px;
    color: var(--splash);
  }

  .track__indicator::before,
  .track__indicator::after {
    content: "";
    position: absolute;
    background: currentColor;
    transition: transform 200ms var(--ease-quart);
  }

  .track__indicator::before {
    top: 50%; left: 0;
    width: 100%; height: 2px;
    transform: translateY(-50%);
  }

  .track__indicator::after {
    top: 0; left: 50%;
    width: 2px; height: 100%;
    transform: translateX(-50%);
  }

  .track[open] .track__indicator::after {
    transform: translateX(-50%) rotate(90deg) scaleX(0);
  }

  .tier-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 20px;
    border-top: 1px solid var(--border-soft);
  }

  /* Tier accordion: native <details>/<summary>, no JS. Click summary to expand.
   * Closed: shows tier number, duration, name. Open: adds Who/What/Why + CTA. */
  .tier {
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    transition: border-color 180ms var(--ease-quart), background 180ms var(--ease-quart);
  }

  .tier[open] {
    border-color: var(--accent-soft);
    background: var(--surface-card-open);
  }

  .tier__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 22px 24px;
    transition: background 140ms;
  }

  /* Hide native disclosure markers */
  .tier__summary::-webkit-details-marker {
    display: none;
  }
  .tier__summary::marker {
    display: none;
  }

  .tier__summary:hover {
    background: var(--accent-faint);
  }

  .tier__summary:focus-visible {
    outline: 2px solid var(--splash);
    outline-offset: 2px;
    background: var(--accent-faint);
  }

  .tier__summary-text {
    flex: 1;
    min-width: 0;
  }

  .tier__meta {
    margin: 0 0 8px;
    color: var(--splash);
  }

  .tier__name {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--paper);
    margin: 0;
    max-width: 22ch;
  }

  /* Plus/minus indicator. CSS-only: two pseudo-elements form a plus,
   * vertical one collapses on open to make a minus. */
  .tier__indicator {
    position: relative;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--splash);
  }

  .tier__indicator::before,
  .tier__indicator::after {
    content: "";
    position: absolute;
    background: currentColor;
    transition: transform 200ms var(--ease-quart);
  }

  .tier__indicator::before {
    /* horizontal bar */
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }

  .tier__indicator::after {
    /* vertical bar (rotates to disappear on open) */
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }

  .tier[open] .tier__indicator::after {
    transform: translateX(-50%) rotate(90deg) scaleX(0);
  }

  /* Expanded content */
  .tier__expanded {
    padding: 20px 24px 28px;
    border-top: 1px solid var(--border-soft);
  }

  .tier__section + .tier__section {
    margin-top: 18px;
  }

  .tier__sub-label {
    margin: 0 0 6px;
    color: var(--paper-muted);
  }

  .tier__body {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--paper-soft);
  }

  .tier__body--italic {
    font-style: italic;
    color: var(--paper-soft);
  }

  .tier__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tier__list li {
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--paper-soft);
    padding-left: 16px;
    position: relative;
    margin-bottom: 6px;
  }

  .tier__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 6px;
    height: 1px;
    background: var(--splash);
  }

  .tier__cta {
    display: inline-block;
    margin-top: 22px;
    padding: 12px 4px;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--paper);
    border-bottom: 2px solid var(--splash);
    text-decoration: none;
    transition: padding 140ms var(--ease-quart), border-bottom-width 140ms var(--ease-quart);
  }

  /* Hover keeps text in --paper (preserves contrast over the open-tier surface);
   * emphasis shifts to a thicker border and slight horizontal advance to convey
   * forward motion. Avoids the gold-on-blue text contrast drop. */
  .tier__cta:hover,
  .tier__cta:focus-visible {
    padding-right: 12px;
    border-bottom-width: 3px;
    outline: none;
  }

  .tier__cta:focus-visible {
    outline: 2px solid var(--splash);
    outline-offset: 4px;
  }

  .engage__footer {
    margin-top: 96px;
    padding-top: 32px;
    border-top: 1px solid var(--border-strong);
    text-align: center;
  }

  .engage__footer-body {
    margin: 12px auto 0;
    font-size: 16px;
    line-height: 1.55;
    color: var(--paper-soft);
    max-width: 60ch;
  }

  /* Reduced-motion handled site-wide via global.css */
</style>
