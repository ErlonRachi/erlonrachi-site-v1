---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PaintedHighlight from "../../components/PaintedHighlight.astro";
import { PILLARS, PILLAR_ORDER, groupByPillar, sortByDateDesc } from "../../data/writing";

const essays = (await getCollection("essays")).filter((e) => !e.data.draft);
const grouped = groupByPillar(essays);
const totalEssays = essays.length;

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "short",
});
---

<Layout
  title="Writing — Erlon Rachi"
  description="Essays on agentic AI, governance, data infrastructure, leadership, the human factor, and field notes from Europe and beyond."
>
  <main class="writing mx-auto max-w-[920px] px-6 py-16 md:py-24">
    <p class="label-mono">Writing</p>
    <h1 class="display-xl writing__h1">
      Essays on <PaintedHighlight>data, AI, and the people behind both</PaintedHighlight>.
    </h1>

    <p class="writing__lead">
      Working notes and longer-form thinking from the field. Organised by pillar so you can read by what you actually care about. Published first here, syndicated to LinkedIn later.
    </p>

    {PILLAR_ORDER.map((slug) => {
      const pillar = PILLARS[slug];
      const list = sortByDateDesc(grouped.get(slug) ?? []);
      return (
        <section class="pillar" id={slug}>
          <header class="pillar__header">
            <p class="label-mono">{pillar.short}</p>
            <h2 class="pillar__title">{pillar.title}</h2>
            <p class="pillar__sub">{pillar.description}</p>
          </header>
          {list.length === 0 ? (
            <p class="pillar__empty">No essays in this pillar yet. Coming soon.</p>
          ) : (
            <ul class="pillar__list">
              {list.map((e) => (
                <li class="essay-row">
                  <a href={`/writing/${e.id}`} class="essay-link">
                    <time class="essay-row__date" datetime={e.data.publishedDate.toISOString()}>
                      {dateFmt.format(e.data.publishedDate)}
                    </time>
                    <span class="essay-row__title">{e.data.title}</span>
                    {e.data.description && (
                      <span class="essay-row__desc">{e.data.description}</span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      );
    })}

    <footer class="writing__footer">
      <p class="label-mono">
        {totalEssays} essays published · own-domain first, LinkedIn syndication second
      </p>
    </footer>
  </main>
</Layout>

<style>
  .writing__h1 {
    margin: 14px 0 36px;
    max-width: 20ch;
  }

  .writing__lead {
    font-size: 19px;
    line-height: 1.65;
    color: var(--paper);
    max-width: 65ch;
    margin: 0 0 88px;
  }

  .pillar {
    margin-top: 72px;
    scroll-margin-top: 80px;
  }

  .pillar:first-of-type {
    margin-top: 0;
  }

  .pillar__header {
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 2px solid var(--accent-soft);
  }

  .pillar__title {
    font-family: "Newsreader", Georgia, serif;
    font-weight: 500;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.16;
    letter-spacing: -0.012em;
    color: var(--paper);
    margin: 6px 0 10px;
  }

  .pillar__sub {
    font-size: 15px;
    line-height: 1.55;
    color: var(--paper-soft);
    margin: 0;
    font-style: italic;
    max-width: 56ch;
  }

  .pillar__empty {
    font-size: 15px;
    color: var(--paper-muted);
    font-style: italic;
    margin: 12px 0 0;
  }

  .pillar__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .essay-row {
    margin: 0;
    border-bottom: 1px solid var(--border-medium);
  }

  .essay-row:last-child {
    border-bottom: 0;
  }

  .essay-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    padding: 20px 0;
    text-decoration: none;
    color: inherit;
    transition: background 160ms var(--ease-quart);
  }

  @media (min-width: 720px) {
    .essay-link {
      grid-template-columns: 110px 1fr;
      gap: 28px;
      align-items: baseline;
    }
  }

  .essay-link:hover,
  .essay-link:focus-visible {
    background: var(--accent-faint-grad);
    outline: none;
  }

  .essay-link:focus-visible {
    outline: 2px solid var(--splash);
    outline-offset: 2px;
  }

  .essay-row__date {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--paper-muted);
    font-variant-numeric: tabular-nums;
    padding-top: 2px;
  }

  @media (min-width: 720px) {
    .essay-row__date {
      grid-row: 1 / span 2;
    }
  }

  .essay-row__title {
    font-family: "Newsreader", Georgia, serif;
    font-weight: 500;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: -0.008em;
    color: var(--paper);
    max-width: 58ch;
  }

  .essay-row__desc {
    font-size: 15.5px;
    line-height: 1.5;
    color: var(--paper-soft);
    max-width: 60ch;
  }

  .writing__footer {
    margin-top: 96px;
    padding-top: 24px;
    border-top: 1px solid var(--border-strong);
  }

  .writing__footer p {
    margin: 0;
    color: var(--paper-muted);
  }
</style>
