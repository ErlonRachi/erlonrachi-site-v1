---
import Layout from "../layouts/Layout.astro";
import DevNav from "../components/DevNav.astro";
import PaintedHighlight from "../components/PaintedHighlight.astro";

const paths = [
  {
    href: "/work",
    label: "Know my project portfolio",
    meta: "32 cases · six themes",
    sub: "Scan by competency. Each case stands alone. The whole tells the arc.",
  },
  {
    href: "/work-with-me",
    label: "Let's work together",
    meta: "two productized tracks · six tiers",
    sub: "An executive in your decision room, or a builder in your codebase. Pick the lane that fits the problem.",
  },
  {
    href: "/story",
    label: "Read my Story",
    meta: "the operator behind the work",
    sub: "Italian, Brazilian, European. UNICAMP. The philosophy of building people before building code.",
  },
];
---

<Layout
  title="Erlon Rachi — Senior data and AI leadership and execution"
  description="Senior data and AI work across 27+ markets, productized into two engagement tracks. 32 case studies, USD 250MM+ in delivered value."
>
  <DevNav />

  <main class="home mx-auto max-w-[960px] px-6 py-20 md:py-28">
    <p class="label-mono home__id">
      Erlon Rachi · Milan · CET
    </p>

    <h1 class="display-xl home__h1">
      Senior data and AI <PaintedHighlight>leadership and execution</PaintedHighlight>.
    </h1>

    <p class="home__lead">
      Twenty years of building data organisations: fractional in the decision room, hands-on in the codebase. Eleven of those years are documented on this site: thirty-two case studies across more than twenty-seven markets, for clients from early-stage startups to multi-billion-euro enterprises and Fortune 500s.
    </p>

    <dl class="home__proof">
      <div class="home__proof-cell">
        <dt class="label-mono">Value delivered</dt>
        <dd>USD 250M+</dd>
      </div>
      <div class="home__proof-cell">
        <dt class="label-mono">Portfolio timeline</dt>
        <dd>11 years</dd>
      </div>
      <div class="home__proof-cell">
        <dt class="label-mono">Cases in my portfolio</dt>
        <dd>32</dd>
      </div>
      <div class="home__proof-cell">
        <dt class="label-mono">Markets</dt>
        <dd>27+</dd>
      </div>
    </dl>

    <section class="home__paths" aria-label="Primary entry points">
      {paths.map((p) => (
        <a href={p.href} class="path">
          <p class="label-mono path__meta">{p.meta}</p>
          <h2 class="path__label">{p.label} <span class="path__arrow" aria-hidden="true">→</span></h2>
          <p class="path__sub">{p.sub}</p>
        </a>
      ))}
    </section>

    <aside class="home__fulltime">
      <p class="label-mono">Open to join your organization</p>
      <p>
        I am open to senior full-time roles, scaling up companies or full enterprise. Let's have a conversation about how we can merge our paths. Send me a message on
        <a href="https://www.linkedin.com/in/erlonrachi/" rel="me noopener">LinkedIn</a>.
      </p>
    </aside>

    <footer class="home__footer">
      <p class="label-mono">© {new Date().getFullYear()} Erlon Rachi.</p>
    </footer>
  </main>
</Layout>

<style>
  .home__id {
    margin: 0 0 28px;
  }

  .home__h1 {
    margin: 0 0 36px;
    max-width: 18ch;
  }

  .home__lead {
    font-size: 19px;
    line-height: 1.65;
    color: var(--paper);
    max-width: 65ch;
    margin: 0 0 56px;
  }

  /* Proof bar: 4 cells, same card treatment as path cards below for visual
   * parity. Stacks 1-col mobile → 2-col tablet → 4-col desktop. */
  .home__proof {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin: 0 0 80px;
  }

  @media (min-width: 600px) {
    .home__proof {
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  }

  @media (min-width: 880px) {
    .home__proof {
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
  }

  .home__proof-cell {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding: 28px 24px;
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    min-height: 130px;
  }

  .home__proof-cell dt {
    margin: 0;
    color: var(--paper-muted);
  }

  .home__proof-cell dd {
    margin: 0;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: clamp(26px, 2.8vw, 34px);
    line-height: 1.05;
    color: var(--paper);
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }

  /* Paths: 3 cards stacked on mobile, 3-col on desktop */
  .home__paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin: 0 0 80px;
  }

  @media (min-width: 880px) {
    .home__paths {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
    }
  }

  .path {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 28px 28px 32px;
    background: var(--surface-card);
    border: 1px solid var(--border-soft);
    text-decoration: none;
    color: inherit;
    transition: border-color 180ms var(--ease-quart), background 180ms var(--ease-quart);
  }

  .path:hover,
  .path:focus-visible {
    border-color: var(--accent-strong);
    background: var(--surface-card-open);
    outline: none;
  }

  .path__meta {
    margin: 0 0 12px;
    color: var(--paper-muted);
  }

  .path__label {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 500;
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: var(--paper);
    margin: 0 0 14px;
  }

  .path__arrow {
    display: inline-block;
    color: var(--splash);
    margin-left: 2px;
    transition: transform 180ms var(--ease-quart);
  }

  .path:hover .path__arrow {
    transform: translateX(4px);
  }

  .path__sub {
    font-size: 15.5px;
    line-height: 1.55;
    color: var(--paper-soft);
    margin: 0 auto;
    max-width: 36ch;
  }

  /* Full-time aside: spans the full width of the path grid above, centered.
   * Gold accent moves from left border to top border so the visual frame
   * works with centered content. */
  .home__fulltime {
    padding: 32px 28px;
    border-top: 2px solid var(--accent-soft);
    background: var(--surface-tint);
    margin: 0 0 80px;
    text-align: center;
  }

  .home__fulltime .label-mono {
    margin: 0 0 12px;
  }

  .home__fulltime p:last-child {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--paper-soft);
    margin: 0 auto;
    max-width: 60ch;
  }

  .home__fulltime a {
    color: var(--paper);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent-link);
    transition: text-decoration-color 140ms;
  }

  .home__fulltime a:hover {
    text-decoration-color: var(--splash);
  }

  /* Footer: one line, period. */
  .home__footer {
    margin-top: 96px;
    padding-top: 24px;
    border-top: 1px solid var(--border-strong);
  }

  .home__footer p {
    margin: 0;
    color: var(--paper-muted);
  }
</style>
